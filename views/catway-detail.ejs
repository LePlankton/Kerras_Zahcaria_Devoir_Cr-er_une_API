<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Catway n°<%= catway.catwayNumber %> - Port de Plaisance Russell</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f0f4f8;
            margin: 0;
            padding: 0;
        }

        nav {
            background-color: #1e3a5f;
            padding: 15px 30px;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin-right: 20px;
            font-size: 14px;
        }

        nav a:hover {
            text-decoration: underline;
        }

        .contenu {
            padding: 30px;
        }

        h1, h2 {
            color: #1e3a5f;
            margin-bottom: 15px;
        }

        .carte {
            background-color: white;
            padding: 20px;
            border-radius: 6px;
            border-left: 4px solid #2e6da4;
            margin-bottom: 30px;
            max-width: 500px;
        }

        .carte p {
            margin: 8px 0;
            font-size: 15px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background-color: white;
        }

        th {
            background-color: #1e3a5f;
            color: white;
            padding: 10px;
            text-align: left;
        }

        td {
            padding: 8px 10px;
            border-bottom: 1px solid #ddd;
        }

        tr:nth-child(even) {
            background-color: #f0f5fa;
        }

        .btn-modifier {
            background-color: #2e6da4;
            color: white;
            padding: 7px 14px;
            border-radius: 4px;
            text-decoration: none;
            font-size: 13px;
            margin-right: 5px;
        }

        .btn-supprimer {
            background-color: #e74c3c;
            color: white;
            border: none;
            padding: 7px 14px;
            border-radius: 4px;
            font-size: 13px;
            cursor: pointer;
        }

        .btn-supprimer:hover {
            background-color: #c0392b;
        }
    </style>
</head>
<body>

    <nav>
        <a href="/dashboard">Dashboard</a>
        <a href="/dashboard/catways">← Retour aux catways</a>
        <a href="/auth/logout">Se déconnecter</a>
    </nav>

    <div class="contenu">
        <h1>Catway n°<%= catway.catwayNumber %></h1>

        <div class="carte">
            <p><b>Numéro :</b> <%= catway.catwayNumber %></p>
            <p><b>Type :</b> <%= catway.catwayType === 'long' ? 'Long' : 'Court' %></p>
            <p><b>État :</b> <%= catway.catwayState %></p>
        </div>

        <a href="/dashboard/catways/<%= catway.catwayNumber %>/edit" class="btn-modifier">Modifier</a>
        <form method="POST" action="/dashboard/catways/<%= catway.catwayNumber %>/delete" style="display:inline;" onsubmit="return confirm('Supprimer ce catway ?')">
            <button type="submit" class="btn-supprimer">Supprimer</button>
        </form>

        <h2 style="margin-top: 30px;">Réservations de ce catway</h2>

        <% if (reservations.length === 0) { %>
            <p>Aucune réservation pour ce catway.</p>
        <% } else { %>
        <table>
            <tr>
                <th>Client</th>
                <th>Bateau</th>
                <th>Début</th>
                <th>Fin</th>
            </tr>
            <% reservations.forEach(r => { %>
            <tr>
                <td><%= r.clientName %></td>
                <td><%= r.boatName %></td>
                <td><%= new Date(r.startDate).toLocaleDateString('fr-FR') %></td>
                <td><%= new Date(r.endDate).toLocaleDateString('fr-FR') %></td>
            </tr>
            <% }) %>
        </table>
        <% } %>
    </div>

</body>
</html>
