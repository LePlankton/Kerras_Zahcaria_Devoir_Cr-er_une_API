<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - Port de Plaisance Russell</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f0f4f8;
            margin: 0;
            padding: 0;
        }

        nav {
            background-color: #1e3a5f;
            padding: 15px 30px;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin-right: 20px;
            font-size: 14px;
        }

        nav a:hover {
            text-decoration: underline;
        }

        .contenu {
            padding: 30px;
        }

        h1 {
            color: #1e3a5f;
            margin-bottom: 5px;
        }

        .info-utilisateur {
            color: #555;
            margin-bottom: 25px;
        }

        .stats {
            background-color: white;
            border-left: 4px solid #2e6da4;
            padding: 15px 20px;
            margin-bottom: 30px;
            border-radius: 4px;
            display: inline-block;
            margin-right: 20px;
        }

        .stats p {
            margin: 0;
            font-size: 15px;
            color: #333;
        }

        .stats span {
            font-size: 28px;
            font-weight: bold;
            color: #1e3a5f;
        }

        h2 {
            color: #1e3a5f;
            margin-bottom: 15px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background-color: white;
        }

        th {
            background-color: #1e3a5f;
            color: white;
            padding: 10px;
            text-align: left;
        }

        td {
            padding: 8px 10px;
            border-bottom: 1px solid #ddd;
        }

        tr:nth-child(even) {
            background-color: #f0f5fa;
        }
        @media (max-width: 768px) {
            nav {
                padding: 10px 15px;
            }
            nav a {
                display: inline-block;
                margin: 4px 5px;
                font-size: 13px;
            }
            .contenu {
                padding: 15px;
            }
            table {
                display: block;
                overflow-x: auto;
            }
            .stats {
                display: block;
                margin-bottom: 15px;
            }
        }
    </style>
</head>
<body>

    <nav>
        <a href="/dashboard/catways">Catways</a>
        <a href="/dashboard/reservations">Réservations</a>
        <a href="/dashboard/users">Utilisateurs</a>
        <a href="/api-docs">Documentation API</a>
        <a href="/auth/logout">Se déconnecter</a>
    </nav>

    <div class="contenu">

        <h1>Tableau de bord</h1>
        <p class="info-utilisateur">
            Connecté en tant que : <b><%= user.username %></b> (<%= user.email %>) —
            <%= new Date().toLocaleDateString('fr-FR') %>
        </p>

        <div class="stats">
            <span><%= catways.length %></span>
            <p>Catways enregistrés</p>
        </div>

        <div class="stats">
            <span><%= reservations.length %></span>
            <p>Réservations au total</p>
        </div>

        <h2>Réservations en cours</h2>

        <% if (reservations.length === 0) { %>
            <p>Aucune réservation enregistrée.</p>
        <% } else { %>
        <table>
            <tr>
                <th>Catway n°</th>
                <th>Client</th>
                <th>Bateau</th>
                <th>Début</th>
                <th>Fin</th>
            </tr>
            <% reservations.forEach(r => { %>
            <tr>
                <td><%= r.catwayNumber %></td>
                <td><%= r.clientName %></td>
                <td><%= r.boatName %></td>
                <td><%= new Date(r.startDate).toLocaleDateString('fr-FR') %></td>
                <td><%= new Date(r.endDate).toLocaleDateString('fr-FR') %></td>
            </tr>
            <% }) %>
        </table>
        <% } %>

    </div>

</body>
</html>
