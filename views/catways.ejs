<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Catways - Port de Plaisance Russell</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f0f4f8;
            margin: 0;
            padding: 0;
        }

        nav {
            background-color: #1e3a5f;
            padding: 15px 30px;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin-right: 20px;
            font-size: 14px;
        }

        nav a:hover {
            text-decoration: underline;
        }

        .contenu {
            padding: 30px;
        }

        h1 {
            color: #1e3a5f;
            margin-bottom: 20px;
        }

        .btn-nouveau {
            background-color: #27ae60;
            color: white;
            padding: 8px 16px;
            border-radius: 4px;
            text-decoration: none;
            font-size: 14px;
            display: inline-block;
            margin-bottom: 20px;
        }

        .btn-nouveau:hover {
            background-color: #219a52;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background-color: white;
        }

        th {
            background-color: #1e3a5f;
            color: white;
            padding: 10px;
            text-align: left;
        }

        td {
            padding: 8px 10px;
            border-bottom: 1px solid #ddd;
        }

        tr:nth-child(even) {
            background-color: #f0f5fa;
        }

        .btn-action {
            padding: 5px 10px;
            border-radius: 4px;
            text-decoration: none;
            font-size: 13px;
            margin-right: 5px;
            color: white;
        }

        .btn-detail { background-color: #7f8c8d; }
        .btn-modifier { background-color: #2e6da4; }

        .btn-supprimer {
            background-color: #e74c3c;
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 4px;
            font-size: 13px;
            cursor: pointer;
        }

        .btn-supprimer:hover {
            background-color: #c0392b;
        }
        @media (max-width: 768px) {
            nav { padding: 10px 15px; }
            nav a { display: inline-block; margin: 4px 5px; font-size: 13px; }
            .contenu { padding: 15px; }
            table { display: block; overflow-x: auto; }
        }
    </style>
</head>
<body>

    <nav>
        <a href="/dashboard">Dashboard</a>
        <a href="/dashboard/reservations">Réservations</a>
        <a href="/dashboard/users">Utilisateurs</a>
        <a href="/api-docs">Documentation API</a>
        <a href="/auth/logout">Se déconnecter</a>
    </nav>

    <div class="contenu">
        <h1>Liste des catways</h1>
        <a href="/dashboard/catways/new" class="btn-nouveau">+ Nouveau catway</a>

        <table>
            <tr>
                <th>Numéro</th>
                <th>Type</th>
                <th>État</th>
                <th>Actions</th>
            </tr>
            <% catways.forEach(catway => { %>
            <tr>
                <td><%= catway.catwayNumber %></td>
                <td><%= catway.catwayType === 'long' ? 'Long' : 'Court' %></td>
                <td><%= catway.catwayState %></td>
                <td>
                    <a href="/dashboard/catways/<%= catway.catwayNumber %>" class="btn-action btn-detail">Détail</a>
                    <a href="/dashboard/catways/<%= catway.catwayNumber %>/edit" class="btn-action btn-modifier">Modifier</a>
                    <form method="POST" action="/dashboard/catways/<%= catway.catwayNumber %>/delete" style="display:inline;" onsubmit="return confirm('Supprimer ce catway ?')">
                        <button type="submit" class="btn-supprimer">Supprimer</button>
                    </form>
                </td>
            </tr>
            <% }) %>
        </table>
    </div>

</body>
</html>
