<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Utilisateurs - Port de Plaisance Russell</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f0f4f8;
            margin: 0;
            padding: 0;
        }

        nav {
            background-color: #1e3a5f;
            padding: 15px 30px;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin-right: 20px;
            font-size: 14px;
        }

        nav a:hover {
            text-decoration: underline;
        }

        .contenu {
            padding: 30px;
        }

        h1 {
            color: #1e3a5f;
            margin-bottom: 20px;
        }

        .btn-nouveau {
            background-color: #27ae60;
            color: white;
            padding: 8px 16px;
            border-radius: 4px;
            text-decoration: none;
            font-size: 14px;
            display: inline-block;
            margin-bottom: 20px;
        }

        .btn-nouveau:hover {
            background-color: #219a52;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background-color: white;
        }

        th {
            background-color: #1e3a5f;
            color: white;
            padding: 10px;
            text-align: left;
        }

        td {
            padding: 8px 10px;
            border-bottom: 1px solid #ddd;
        }

        tr:nth-child(even) {
            background-color: #f0f5fa;
        }

        .btn-modifier {
            background-color: #2e6da4;
            color: white;
            padding: 5px 10px;
            border-radius: 4px;
            text-decoration: none;
            font-size: 13px;
            margin-right: 5px;
        }

        .btn-supprimer {
            background-color: #e74c3c;
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 4px;
            font-size: 13px;
            cursor: pointer;
        }

        .btn-supprimer:hover {
            background-color: #c0392b;
        }
        @media (max-width: 768px) {
            nav { padding: 10px 15px; }
            nav a { display: inline-block; margin: 4px 5px; font-size: 13px; }
            .contenu { padding: 15px; }
            table { display: block; overflow-x: auto; }
        }
    </style>
</head>
<body>

    <nav>
        <a href="/dashboard">Dashboard</a>
        <a href="/dashboard/catways">Catways</a>
        <a href="/dashboard/reservations">Réservations</a>
        <a href="/api-docs">Documentation API</a>
        <a href="/auth/logout">Se déconnecter</a>
    </nav>

    <div class="contenu">
        <h1>Utilisateurs</h1>
        <a href="/dashboard/users/new" class="btn-nouveau">+ Nouvel utilisateur</a>

        <% if (users.length === 0) { %>
            <p>Aucun utilisateur enregistré.</p>
        <% } else { %>
        <table>
            <tr>
                <th>Nom d'utilisateur</th>
                <th>Email</th>
                <th>Créé le</th>
                <th>Actions</th>
            </tr>
            <% users.forEach(u => { %>
            <tr>
                <td><%= u.username %></td>
                <td><%= u.email %></td>
                <td><%= new Date(u.createdAt).toLocaleDateString('fr-FR') %></td>
                <td>
                    <a href="/dashboard/users/<%= u.email %>/edit" class="btn-modifier">Modifier</a>
                    <form method="POST" action="/dashboard/users/<%= u.email %>/delete" style="display:inline;" onsubmit="return confirm('Supprimer cet utilisateur ?')">
                        <button type="submit" class="btn-supprimer">Supprimer</button>
                    </form>
                </td>
            </tr>
            <% }) %>
        </table>
        <% } %>
    </div>

</body>
</html>
