<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title><%= reservation ? 'Modifier' : 'Créer' %> une réservation - Port de Plaisance Russell</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f0f4f8;
            margin: 0;
            padding: 0;
        }

        nav {
            background-color: #1e3a5f;
            padding: 15px 30px;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin-right: 20px;
            font-size: 14px;
        }

        nav a:hover {
            text-decoration: underline;
        }

        .contenu {
            padding: 30px;
        }

        h1 {
            color: #1e3a5f;
            margin-bottom: 20px;
        }

        form {
            background-color: white;
            padding: 25px;
            border-radius: 6px;
            max-width: 450px;
        }

        label {
            display: block;
            font-weight: bold;
            margin-bottom: 5px;
            color: #333;
        }

        input {
            width: 100%;
            padding: 8px;
            margin-bottom: 15px;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-size: 14px;
            box-sizing: border-box;
        }

        .erreur {
            color: red;
            margin-bottom: 15px;
        }

        .btn-valider {
            background-color: #1e3a5f;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            font-size: 14px;
            cursor: pointer;
        }

        .btn-valider:hover {
            background-color: #2e6da4;
        }

        .lien-annuler {
            margin-left: 15px;
            color: #2e6da4;
        }
        @media (max-width: 768px) {
            nav { padding: 10px 15px; }
            nav a { display: inline-block; margin: 4px 5px; font-size: 13px; }
            .contenu { padding: 15px; }
            form { max-width: 100%; }
        }
    </style>
</head>
<body>

    <nav>
        <a href="/dashboard">Dashboard</a>
        <a href="/dashboard/reservations">← Retour aux réservations</a>
        <a href="/auth/logout">Se déconnecter</a>
    </nav>

    <div class="contenu">
        <h1><%= reservation ? 'Modifier la réservation' : 'Nouvelle réservation' %></h1>

        <% if (typeof error !== 'undefined') { %>
            <p class="erreur"><%= error %></p>
        <% } %>

        <form method="POST" action="<%= reservation ? '/dashboard/reservations/' + reservation._id + '/edit' : '/dashboard/reservations' %>">

            <label for="catwayNumber">Numéro de catway</label>
            <input type="number" id="catwayNumber" name="catwayNumber" required value="<%= reservation ? reservation.catwayNumber : '' %>" placeholder="Ex: 1" />

            <label for="clientName">Nom du client</label>
            <input type="text" id="clientName" name="clientName" required value="<%= reservation ? reservation.clientName : '' %>" placeholder="Ex: Jean Dupont" />

            <label for="boatName">Nom du bateau</label>
            <input type="text" id="boatName" name="boatName" required value="<%= reservation ? reservation.boatName : '' %>" placeholder="Ex: Le Téméraire" />

            <label for="startDate">Date de début</label>
            <input type="date" id="startDate" name="startDate" required value="<%= reservation ? new Date(reservation.startDate).toISOString().split('T')[0] : '' %>" />

            <label for="endDate">Date de fin</label>
            <input type="date" id="endDate" name="endDate" required value="<%= reservation ? new Date(reservation.endDate).toISOString().split('T')[0] : '' %>" />

            <button type="submit" class="btn-valider"><%= reservation ? 'Enregistrer' : 'Créer' %></button>
            <a href="/dashboard/reservations" class="lien-annuler">Annuler</a>
        </form>
    </div>

</body>
</html>
